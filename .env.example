# SearchOS 模型配置示例 — 复制为 .env 并按需取消注释
#
# 快速开始：选一个 SF_PROVIDER 预设 + 填对应 API key 即可跑通全部 12 个模型角色。
# 完整说明见 docs/providers.md；精细覆写（单角色换模型等）见 searchos/config/settings.py。

# ============================================================
# 方式一：厂商 Coding Plan（Anthropic 协议，按月订阅，性价比高）
# ============================================================

# --- 智谱 GLM Coding Plan（中国站 bigmodel.cn）---
# SF_PROVIDER=zhipu-coding
# ZHIPU_API_KEY=xxx            # Coding Plan 套餐页获取

# --- Z.ai GLM Coding Plan（国际站）---
# SF_PROVIDER=zai-coding
# ZAI_API_KEY=xxx

# --- Kimi For Coding 订阅（kimi.com/code/console 创建专属 Key）---
# SF_PROVIDER=kimi-coding
# KIMI_API_KEY=xxx

# --- MiniMax Coding Plan（国际站加 SF_API_BASE=https://api.minimax.io/anthropic）---
# SF_PROVIDER=minimax-coding
# MINIMAX_API_KEY=xxx

# --- 阿里百炼 Qwen 编程套餐（sk-sp- 前缀专属 Key；注意条款限编程工具使用）---
# SF_PROVIDER=qwen-coding
# DASHSCOPE_API_KEY=sk-sp-xxx

# --- 火山方舟 Coding Plan ---
# SF_PROVIDER=volcengine-coding
# ARK_API_KEY=xxx

# ============================================================
# 方式二：按量 API（OpenAI 协议）
# ============================================================

# --- DeepSeek ---
# SF_PROVIDER=deepseek
# DEEPSEEK_API_KEY=xxx

# --- 智谱按量 / Moonshot(Kimi) 按量 / MiniMax 按量 / 阿里百炼按量 / 火山按量 ---
# SF_PROVIDER=zhipu        # + ZHIPU_API_KEY
# SF_PROVIDER=moonshot     # + MOONSHOT_API_KEY（别名 kimi）
# SF_PROVIDER=minimax      # + MINIMAX_API_KEY
# SF_PROVIDER=dashscope    # + DASHSCOPE_API_KEY（别名 qwen）
# SF_PROVIDER=volcengine   # + ARK_API_KEY（别名 doubao / ark）

# --- OpenAI / Anthropic 官方 ---
# SF_PROVIDER=openai
# OPENAI_API_KEY=sk-xxx
# SF_PROVIDER=anthropic    # 仅支持 Console API key（订阅 OAuth token 违反 ToS）
# ANTHROPIC_API_KEY=sk-ant-xxx

# --- 聚合平台 ---
# SF_PROVIDER=openrouter   # + OPENROUTER_API_KEY，模型 id 为 vendor/model
# SF_PROVIDER=siliconflow  # + SILICONFLOW_API_KEY
# SF_PROVIDER=gemini       # + GEMINI_API_KEY
# SF_PROVIDER=xai          # + XAI_API_KEY

# ============================================================
# 方式三：本地部署（必须指定 SF_MODEL）
# ============================================================

# SF_PROVIDER=ollama
# SF_MODEL=qwen3:32b       # ollama list 中的模型名

# SF_PROVIDER=vllm
# SF_MODEL=Qwen/Qwen3-32B  # vllm serve 启动的模型路径或 --served-model-name
# SF_API_BASE=http://localhost:8000/v1

# ============================================================
# 可选微调（对任意预设生效）
# ============================================================

# SF_MODEL=...             # 覆盖主力模型（orchestrator/sub_agent/reformat 等）
# SF_FAST_MODEL=...        # 覆盖轻量档模型（extraction/judge/synthesis）
# SF_API_BASE=...          # 覆盖端点（如切国际站域名）
# SF_API_KEY_ENV=...       # 从其它环境变量名读 key
# SF_PROFILES__MAIN__TEMPERATURE=0.3     # 单 profile 字段级覆写（深合并）
# SF_ROLES__EXTRACTION=main              # 单角色改绑 profile

# ============================================================
# 搜索后端（Web 搜索 API，与模型厂商无关）
# ============================================================
# 不设 SF_SEARCH_PROVIDER 时按已有 key 自动推断（serper → tavily），
# 都没有则回落内部 ragflow（仅蚂蚁内网可用）。

# SF_SEARCH_PROVIDER=serper    # serper | tavily | ragflow
# SERPER_API_KEY=xxx           # serper.dev 注册获取（推荐，Google 结果）
# TAVILY_API_KEY=xxx           # tavily.com；需 pip install 'searchos[tavily]'
# RAGFLOW_ENDPOINT=xxx         # ragflow 后端接口地址（仅内网环境可用）
# RAGFLOW_USER_ID=xxx          # ragflow 后端的 userId 凭证（仅内网环境可用）

# ============================================================
# 其它服务
# ============================================================

# SF_JINA_API_KEY=xxx      # Jina 抓取（不填走未认证配额，易 429）
