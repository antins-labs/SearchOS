# SearchOS .env — 只放密钥（secrets）。复制为 .env 后填入对应 API key 值即可。
#
# 其余所有配置（选哪个厂商、模型卡、角色绑定、搜索后端、并发/重试/超时/代理/
# 缓存目录、技能开关…）都不再写这里，而是由：
#   • `searchos --setup`   首次交互式配置向导
#   • Web 设置页            http://localhost:3000 → Settings
#   • TUI 命令              /effort /skill /search /config
# 统一写入 web_settings.json（overlay），Web 与 CLI/TUI 共享同一份、优先级最高。
# 完整说明见 docs/configuration.md。
#
# 本文件只需要提供 overlay 里各 provider 连接 / 模型卡引用到的 *_API_KEY 值。
# 变量名与你在向导/设置页里选择的连接一致；下面按常见厂商给出占位示例，
# 按需保留、删掉不用的行。

# ============================================================
# 模型 API Key（值 = secret；变量名由你的 provider 连接决定）
# ============================================================

# --- 厂商 Coding Plan / 按量 API ---
# ZHIPU_API_KEY=xxx            # 智谱 GLM（bigmodel.cn）
# ZAI_API_KEY=xxx              # Z.ai GLM（国际站）
# KIMI_API_KEY=xxx             # Kimi For Coding（kimi.com/code/console）
# MOONSHOT_API_KEY=xxx         # Moonshot/Kimi 开放平台
# MINIMAX_API_KEY=xxx          # MiniMax
# DASHSCOPE_API_KEY=xxx        # 阿里百炼 Qwen（编程套餐为 sk-sp- 前缀）
# ARK_API_KEY=xxx              # 火山方舟 Doubao
# DEEPSEEK_API_KEY=xxx         # DeepSeek
# OPENAI_API_KEY=sk-xxx        # OpenAI 官方
# ANTHROPIC_API_KEY=sk-ant-xxx # Anthropic 官方（仅 Console API key）
# OPENROUTER_API_KEY=xxx       # OpenRouter 聚合
# SILICONFLOW_API_KEY=xxx      # 硅基流动
# GEMINI_API_KEY=xxx           # Google Gemini
# XAI_API_KEY=xxx              # xAI Grok
# ANTCHAT_API_KEY=xxx          # AntChat 聚合网关（默认 Theta 连接引用它）

# 本地部署（Ollama/vLLM）通常无需真实 key；向导会自动填占位值。

# ============================================================
# 搜索后端 API Key（选用哪个后端在 overlay/设置页里配，这里只放 key 值）
# ============================================================

# SERPER_API_KEY=xxx           # serper.dev（Google 结果，推荐）
# TAVILY_API_KEY=xxx           # tavily.com（需 pip install 'searchos[tavily]'）
# RAGFLOW_USER_ID=xxx          # RagFlow 后端 userId（仅蚂蚁内网）
# RAGFLOW_ENDPOINT=xxx         # RagFlow 后端接口地址（仅内网）

# ============================================================
# 其它服务 Key
# ============================================================

# JINA_API_KEY=xxx             # Jina 抓取（不填走未认证配额，易 429）
# LANGSMITH_API_KEY=xxx        # LangSmith 追踪（可选；开关在设置里）
